<script>
// ---------- language toggle ----------
function setLang(lang){
  document.documentElement.setAttribute('data-lang', lang);
  document.documentElement.setAttribute('lang', lang);
  document.getElementById('btn-ru').setAttribute('aria-pressed', lang==='ru');
  document.getElementById('btn-en').setAttribute('aria-pressed', lang==='en');
  localStorage.setItem('site-lang', lang);
  restartTyped();
}
(function(){
  var saved = localStorage.getItem('site-lang');
  if(saved) document.documentElement.setAttribute('data-lang', saved);
  document.getElementById('btn-ru').setAttribute('aria-pressed', (saved||'ru')==='ru');
  document.getElementById('btn-en').setAttribute('aria-pressed', saved==='en');
})();

// ---------- terminal typewriter ----------
var TYPED_LINES = {
  ru: ["whoami", "Дмитрий Парамонов — DevOps Team Lead", "cat status.txt", "20+ лет в IT · 9+ лет в DevOps/SRE · открыт к предложениям"],
  en: ["whoami", "Dmitry Paramonov — DevOps Team Lead", "cat status.txt", "20+ years in IT · 9+ years in DevOps/SRE · open to offers"]
};
var typedTimer = null;
function restartTyped(){
  var el = document.getElementById('typed-line');
  if(!el) return;
  if(typedTimer) clearTimeout(typedTimer);
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var lang = document.documentElement.getAttribute('data-lang') || 'ru';
  var seq = TYPED_LINES[lang]; // [command, response, command, response]
  if(reduced){ el.textContent = seq[1] + '   ' + seq[3]; return; }

  var segIndex = 0;   // which of the 4 segments we're typing
  var charIndex = 0;  // char position within the current segment
  el.textContent = '';

  function typeStep(){
    if(segIndex >= seq.length){
      typedTimer = setTimeout(function(){ segIndex = 0; charIndex = 0; el.textContent=''; typeStep(); }, 4000);
      return;
    }
    var segment = seq[segIndex];
    var isCommand = segIndex % 2 === 0;
    if(charIndex === 0 && isCommand && segIndex > 0){ el.textContent += '\n$ '; }
    charIndex++;
    el.textContent += segment.charAt(charIndex - 1);
    if(charIndex < segment.length){
      typedTimer = setTimeout(typeStep, isCommand ? 55 : 22);
    } else {
      segIndex++; charIndex = 0;
      typedTimer = setTimeout(typeStep, isCommand ? 300 : 900);
    }
  }
  typeStep();
}
window.addEventListener('load', restartTyped);

// ---------- scroll progress ----------
window.addEventListener('scroll', function(){
  var h = document.documentElement;
  var pct = (h.scrollTop) / (h.scrollHeight - h.clientHeight) * 100;
  document.getElementById('progress').style.width = pct + '%';
});

// ---------- count-up numbers (real values, no backend needed) ----------
function animateCount(el){
  var target = parseInt(el.getAttribute('data-count'), 10);
  var suffix = el.getAttribute('data-suffix') || '';
  var dur = 900, start = null;
  function step(ts){
    if(!start) start = ts;
    var p = Math.min((ts - start) / dur, 1);
    el.textContent = Math.floor(p * target) + (p >= 1 ? suffix : '');
    if(p < 1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}
var counted = false;
function maybeCount(){
  if(counted) return;
  var stats = document.querySelector('.stats');
  if(!stats) return;
  var r = stats.getBoundingClientRect();
  if(r.top < window.innerHeight){
    counted = true;
    document.querySelectorAll('.stat .num').forEach(animateCount);
  }
}
window.addEventListener('scroll', maybeCount);
window.addEventListener('load', maybeCount);

// ---------- reveal on scroll ----------
var io = new IntersectionObserver(function(entries){
  entries.forEach(function(e){ if(e.isIntersecting) e.target.classList.add('in'); });
}, {threshold:.12});
document.querySelectorAll('.reveal').forEach(function(el){ io.observe(el); });

// ---------- tilt on hero photo ----------
(function(){
  var card = document.getElementById('tilt-card');
  if(!card || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  card.addEventListener('mousemove', function(e){
    var r = card.getBoundingClientRect();
    var x = (e.clientX - r.left) / r.width - .5;
    var y = (e.clientY - r.top) / r.height - .5;
    card.style.transform = 'rotateY(' + (x*14) + 'deg) rotateX(' + (-y*14) + 'deg)';
  });
  card.addEventListener('mouseleave', function(){ card.style.transform = 'rotateY(0) rotateX(0)'; });
})();

// ---------- copy to clipboard ----------
function copyText(text, btn){
  navigator.clipboard.writeText(text).then(function(){
    var old = btn.innerHTML;
    btn.textContent = document.documentElement.getAttribute('data-lang') === 'ru' ? 'скопировано' : 'copied';
    setTimeout(function(){ btn.innerHTML = old; }, 1500);
  });
}
</script>
</body>
</html>
